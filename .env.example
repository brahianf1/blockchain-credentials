# ===================================================================
# Variables de Dominio (Usadas por Traefik para enrutar el tráfico)
# ===================================================================
MOODLE_DOMAIN=
CONTROLLER_DOMAIN=
BESU_RPC_DOMAIN=
BLOCKSCOUT_DOMAIN=
# URL base del emisor usada por OpenID4VC y DID Document (did:web).
ISSUER_URL=


# ===================================================================
# Variables de Moodle
# ===================================================================
MOODLE_DB_NAME=
MOODLE_DB_USER=
MOODLE_DB_PASSWORD=
MOODLE_DB_PORT_EXT=
MOODLECFG_WWWROOT=
MOODLECFG_SSLPROXY=


# ===================================================================
# Capa de Blockchain — Hyperledger Besu (EVM / Smart Contracts)
# ===================================================================
# La conexión RPC interna (BESU_RPC_URL) se inyecta directamente en
# docker-compose.yml como http://besu-node:8545.
# Token compartido para endpoints administrativos (/api/admin/blockchain/*).
# Generar con: openssl rand -hex 32
ADMIN_BOOTSTRAP_TOKEN=


# ===================================================================
# Blockchain Explorer (Blockscout)
# ===================================================================
# Contraseña de la base de datos interna de Blockscout.
# Generar con: openssl rand -hex 16
BLOCKSCOUT_DB_PASSWORD=
# Secreto de la app Elixir (Phoenix). Mínimo 64 caracteres.
# Generar con: openssl rand -base64 48
BLOCKSCOUT_SECRET_KEY_BASE=


# ===================================================================
# Rutas de secretos (Paths en el Host/VPS)
# ===================================================================
# Claves ECDSA P-256 usadas por el controller para firmar credenciales OpenID4VC.
OPENID_PRIVATE_KEY_PATH=
OPENID_PUBLIC_KEY_PATH=


# ===================================================================
# Variables del Portal de Credenciales
# ===================================================================
PORTAL_DB_NAME=portal_db
PORTAL_DB_USER=portal_user
PORTAL_DB_PASSWORD=
PORTAL_JWT_SECRET=
PORTAL_JWT_EXPIRE_MINUTES=1440
MOODLE_PORTAL_JWT_SECRET=
MOODLE_DB_READONLY_USER=moodle_readonly
MOODLE_DB_READONLY_PASSWORD=
PORTAL_FRONTEND_URL=
