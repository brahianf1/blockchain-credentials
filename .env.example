# ===================================================================
# Variables de Dominio (Usadas por Traefik para enrutar el tráfico)
# ===================================================================
MOODLE_DOMAIN=
CONTROLLER_DOMAIN=
ACAPY_DOMAIN=
ACAPY_ADMIN_DOMAIN=
# URL del explorador público del ledger Indy (VON Network Browser).
VON_NETWORK_DOMAIN=
# URL base del emisor usada por OpenID4VC y DID Document (did:web).
ISSUER_URL=


# ===================================================================
# Variables de Moodle
# ===================================================================
MOODLE_DB_NAME=
MOODLE_DB_USER=
MOODLE_DB_PASSWORD=
MOODLE_DB_PORT_EXT=
MOODLECFG_WWWROOT=
MOODLECFG_SSLPROXY=


# ===================================================================
# Variables de ACA-Py (Hyperledger Indy / VON-Network)
# ===================================================================
# Endpoint público del agente ACA-Py (expuesto por Traefik sobre HTTPS).
ACAPY_ENDPOINT=
# URL del genesis del ledger Indy.
# Entorno local con VON-Network propio: http://von-webserver:8000/genesis
# Red de pruebas pública BCovrin:       http://test.bcovrin.vonx.io/genesis
ACAPY_GENESIS_URL=
# Semilla para la generación del DID del issuer (exactamente 32 caracteres).
ACAPY_DID_SEED=
# Nombre de la billetera (wallet) de ACA-Py.
ACAPY_WALLET_NAME=
# Clave de encriptación para la billetera de ACA-Py.
ACAPY_WALLET_KEY=


# ===================================================================
# Capa de Blockchain (consumida por backend/controller/blockchain)
# ===================================================================
# Driver de ledger: "indy" (por defecto) o "null" para entornos sin ledger.
BLOCKCHAIN_DRIVER=indy
# Etiqueta humana del ledger expuesta en las respuestas públicas.
BLOCKCHAIN_NETWORK_NAME=VON Network (Hyperledger Indy)
# URL pública del explorador del ledger (VON Browser).
BLOCKCHAIN_EXPLORER_URL=


# ===================================================================
# Rutas de secretos (Paths en el Host/VPS)
# ===================================================================
# Claves ECDSA P-256 usadas por el controller para firmar credenciales OpenID4VC.
OPENID_PRIVATE_KEY_PATH=
OPENID_PUBLIC_KEY_PATH=


# ===================================================================
# Variables del Portal de Credenciales
# ===================================================================
PORTAL_DB_NAME=portal_db
PORTAL_DB_USER=portal_user
PORTAL_DB_PASSWORD=
PORTAL_JWT_SECRET=
PORTAL_JWT_EXPIRE_MINUTES=1440
MOODLE_PORTAL_JWT_SECRET=
MOODLE_DB_READONLY_USER=moodle_readonly
MOODLE_DB_READONLY_PASSWORD=
PORTAL_FRONTEND_URL=
