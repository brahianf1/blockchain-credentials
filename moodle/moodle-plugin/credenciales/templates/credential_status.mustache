<div class="md3-side-block">
    {{#has_credential}}
        <div class="md3-surface md3-summary-side px-3 py-3 rounded border">
            <div class="d-flex align-items-center mb-2">
                <i class="fa fa-graduation-cap text-success mr-2" style="font-size: 1.2rem;"></i>
                <h5 class="m-0 text-success" style="font-size: 1rem; font-weight: 500;">Curso Completado</h5>
            </div>
            <p class="text-muted small mb-3">Has completado satisfactoriamente <strong>{{course_name}}</strong> el {{exact_time}}.</p>
            
            <a href="{{dashboard_url}}" class="btn btn-outline-primary btn-block btn-sm md3-btn-outlined">
                <i class="fa fa-certificate"></i> Ver mis Credenciales
            </a>
        </div>
    {{/has_credential}}

    {{^has_credential}}
        <div class="md3-surface md3-summary-side px-3 py-3 rounded border text-center text-muted">
            <i class="fa fa-book mb-2" style="font-size: 1.5rem; opacity: 0.5;"></i>
            <p class="small m-0">{{message}}</p>
        </div>
    {{/has_credential}}
</div>
