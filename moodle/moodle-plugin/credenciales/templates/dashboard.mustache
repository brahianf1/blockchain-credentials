<div class="container-fluid md3-container pt-4">
    <div class="d-flex align-items-center mb-4">
        <i class="fa fa-certificate md3-color-primary mr-3" style="font-size: 2rem;"></i>
        <h2 class="md3-page-title m-0">{{#str}}my_certificates, block_credenciales{{/str}}</h2>
    </div>
    
    {{#has_certificates}}
        <div class="row">
            {{#certificates}}
                <div class="col-12 mb-4">
                    <div class="md3-summary-card d-flex flex-column flex-md-row align-items-md-center justify-content-between">
                        
                        <!-- Izquierda: Info del curso -->
                        <div class="md3-card-info flex-grow-1 pr-md-4">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fa fa-university text-muted mr-2" style="font-size: 1.5rem;"></i>
                                <h4 class="md3-card-course-title m-0">{{course_name}}</h4>
                            </div>
                            <p class="md3-card-date text-muted mb-1"><i class="fa fa-flag-checkered"></i> Curso Aprobado el: <strong>{{exact_completion_time}}</strong></p>
                            
                            <p class="md3-card-date text-success mb-0 date-claimed-{{cert_id}} transition-fade" {{^is_claimed}}style="display:none; opacity: 0;"{{/is_claimed}}>
                                <i class="fa fa-shield"></i> Guardado en Billetera el: <strong class="time-text-{{cert_id}}">{{exact_claimed_time}}</strong>
                            </p>
                        </div>

                        <!-- Centro: Status Badges -->
                        <div class="md3-card-status my-3 my-md-0 px-md-4 border-md-left border-md-right text-md-center">
                            <span class="md3-badge md3-badge-pending badge-pending-{{cert_id}} transition-fade" {{^is_pending}}style="display:none;"{{/is_pending}}>
                                <i class="fa fa-clock-o"></i> Pendiente Billetera
                            </span>
                            <span class="md3-badge md3-badge-claimed badge-claimed-{{cert_id}} transition-fade" {{^is_claimed}}style="display:none; opacity: 0;"{{/is_claimed}}>
                                <i class="fa fa-check-circle"></i> Credencial Guardada
                            </span>
                        </div>

                        <!-- Derecha: Actions -->
                        <div class="md3-card-actions pl-md-4 mt-2 mt-md-0" style="min-width: 250px;">
                            <div class="pending-actions-{{cert_id}} transition-fade" {{^is_pending}}style="display:none;"{{/is_pending}} data-poll-id="{{cert_id}}">
                                <button type="button" class="btn btn-block md3-btn-primary" data-toggle="modal" data-target="#qrModal{{cert_id}}">
                                    <i class="fa fa-qrcode"></i> Guardar en Billetera
                                </button>
                                <p class="text-muted small mt-2 mb-0 text-center font-italic"><i class="fa fa-lock"></i> Requisito para ver diploma</p>
                            </div>

                            <div class="claimed-actions-{{cert_id}} transition-fade" {{^is_claimed}}style="display:none; opacity: 0;"{{/is_claimed}}>
                                <button type="button" class="btn btn-block md3-btn-outlined mb-2" data-toggle="modal" data-target="#certModal{{cert_id}}">
                                    <i class="fa fa-search-plus"></i> Ver Diploma Ilustrativo
                                </button>

                                <a href="{{linkedin_share_url}}" target="_blank" class="btn btn-block md3-btn-linkedin mt-2">
                                    <i class="fa fa-linkedin-square"></i> Compartir Logro
                                </a>

                                {{#portal_url}}
                                <a href="{{portal_url}}" target="_blank" class="btn btn-block btn-outline-success mt-2">
                                    <i class="fa fa-external-link"></i> Ir al Portal
                                </a>
                                {{/portal_url}}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal for QR Scan (MD3 Dialog) -->
                <div class="modal fade" id="qrModal{{cert_id}}" tabindex="-1" role="dialog" aria-hidden="true" data-backdrop="static">
                    <div class="modal-dialog modal-dialog-centered" role="document" style="max-width: 400px;">
                        <div class="modal-content md3-modal-content md3-qr-dialog bg-white shadow" style="border-radius: 16px; overflow: hidden;">
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title font-weight-bold text-dark" style="font-size: 1.1rem;"><i class="fa fa-mobile md3-color-primary mr-2"></i> Escanea el Código QR</h5>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body text-center p-4">
                                <div class="alert md3-alert-info text-left small mb-4">
                                    <i class="fa fa-lightbulb-o mb-1" style="font-size: 1.2rem;"></i><br>
                                    <strong>Paso Único:</strong> Abre la app de Billetera en tu celular (ej. DIDRoom o Paradym) y apunta la cámara a este código para asegurar tu certificado de por vida.
                                </div>
                                
                                <div class="qr-container bg-white p-3 rounded d-inline-block border shadow-sm mb-4">
                                    <img src="{{qr_code}}" alt="QR Code" style="width: 200px; height: 200px; display: block; image-rendering: -webkit-optimize-contrast;">
                                </div>
                                
                                <div class="border-top pt-3 text-left">
                                    <p class="text-muted small mb-2"><strong>O alternativamente</strong>, si navegas desde un celular:</p>
                                    <a href="{{invitation_url}}" class="btn btn-block md3-btn-secondary"><i class="fa fa-external-link"></i> Abrir App Billetera Automáticamente</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- End QR Modal -->

                <!-- Modal for the Certificate Full Illustration (MD3 Dialog) -->
                <div class="modal fade" id="certModal{{cert_id}}" tabindex="-1" role="dialog" aria-hidden="true">
                    <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
                        <div class="modal-content md3-modal-content">
                            <div class="modal-header border-0 pb-0">
                                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close" style="opacity:0.8; text-shadow:none;">
                                    <span aria-hidden="true"><i class="fa fa-times-circle" style="font-size: 2rem;"></i></span>
                                </button>
                            </div>
                            <div class="modal-body p-4 pt-0">
                                <!-- Abstract Realism Certificate Mockup -->
                                <div class="md3-certificate-illustration">
                                    <div class="cert-inner">
                                        <!-- Watermark Background via CSS abstract shapes -->
                                        <div class="cert-watermark"></div>
                                        
                                        <div class="cert-header">
                                            <div class="cert-logo-placeholder">
                                                <strong><i class="fa fa-university mr-2"></i> {{org_name}}</strong>
                                            </div>
                                        </div>
                                        
                                        <div class="cert-body">
                                            <h1>Certifico que</h1>
                                            <h2 class="cert-student">{{student_name}}</h2>
                                            <h3 class="cert-dni">DNI {{student_dni}}</h3>
                                            
                                            <p class="cert-text">
                                                Con fecha {{date}} ha aprobado <strong>'{{course_name}}'</strong><br>
                                                dictado por {{org_name}} con un total de {{hours}} horas reloj.
                                            </p>
                                        </div>
                                        
                                        <div class="cert-footer">
                                            <div class="cert-signatures-svg" style="flex-grow: 1; max-width: 80%; padding-right: 20px;">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1300 350" width="100%" height="auto">
                                                  <defs>
                                                    <style>
                                                      .linea-guia { stroke: #cbd5e1; stroke-width: 2; stroke-linecap: round; }
                                                      .texto-guia { fill: #94a3b8; font-family: sans-serif; font-size: 16px; font-weight: 500; letter-spacing: 2px; text-anchor: middle; }
                                                    </style>
                                                  </defs>

                                                  <!-- FIRMA 1 (IZQUIERDA) -->
                                                  <line x1="80" y1="270" x2="520" y2="270" class="linea-guia" />
                                                  <text x="300" y="300" class="texto-guia">DIRECTOR ACADÉMICO</text>

                                                  <g transform="translate(60, 60) rotate(-5) skewX(-20)" fill="none" stroke="#1e293b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                      <path d="M 80,100 Q 100,68 120,90 T 90,180 Q 60,200 70,150 T 130,130 Q 140,145 150,150 T 170,130 T 180,150 Q 190,100 200,100 T 210,150 T 230,130" />
                                                      <path d="M 280,80 C 230,60 220,160 260,160 C 300,160 310,90 280,80 C 250,70 270,150 310,140 C 370,120 390,150 430,130 C 460,110 480,140 510,120" />
                                                      <path d="M 330,90 C 360,70 400,70 420,80" />
                                                      <path d="M 50,195 Q 280,215 510,185" />
                                                      <path d="M 525,183 L 527,183" stroke-width="5" />
                                                  </g>

                                                  <!-- FIRMA 2 (DERECHA) -->
                                                  <line x1="740" y1="270" x2="1180" y2="270" class="linea-guia" />
                                                  <text x="960" y="300" class="texto-guia">RECTOR DE LA INSTITUCIÓN</text>

                                                  <g transform="translate(700, 80) rotate(-2) skewX(-10)" fill="none" stroke="#0f172a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                                      <path d="M 50,120 Q 70,100 80,150 Q 90,80 100,70 T 120,160 Q 130,90 140,80 T 160,170 Q 170,120 180,130 T 200,170" />
                                                      <path d="M 260,170 L 260,70 C 300,60 320,110 270,120 C 330,120 310,200 260,210 C 220,220 210,190 240,170" />
                                                      <path d="M 240,170 Q 270,140 280,150 T 310,160 Q 330,110 340,110 T 350,160 Q 370,140 380,150 T 410,160 T 440,140 T 470,150" />
                                                      <path d="M 338,85 L 340,85" stroke-width="3" />
                                                  </g>
                                                </svg>
                                            </div>
                                            <div class="cert-public-qr">
                                                <a href="{{public_verify_url}}" target="_blank" title="Verificar en Web Pública (Mock)">
                                                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data={{public_verify_url}}" alt="QR Validación">
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- End Illustration -->
                                
                                <!-- Floating Download Button -->
                                <div class="mt-4 text-center w-100">
                                    <button type="button" class="btn md3-btn-secondary px-4 py-2 shadow-sm" id="downloadBtn{{cert_id}}" onclick="downloadDiplomaAsImage('{{cert_id}}')" style="border-radius: 100px; display: inline-flex; align-items: center; justify-content: center;">
                                        <i class="fa fa-download mr-2" style="font-size: 1.1rem;"></i> Descargar Diploma
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- End Modal -->
            {{/certificates}}
        </div>
    {{/has_certificates}}

    {{^has_certificates}}
        <div class="md3-alert md3-alert-info">
            <i class="fa fa-info-circle mr-2"></i> Aún no has adquirido ninguna credencial. Completá los cursos requeridos para verlas aquí.
        </div>
    {{/has_certificates}}
</div>

{{#has_certificates}}
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const pollElements = document.querySelectorAll('[data-poll-id]');
        if (pollElements.length === 0) return;

        // Poll every 3 seconds
        setInterval(function() {
            pollElements.forEach(el => {
                if (el.style.display === 'none') return; // already claimed

                const certId = el.getAttribute('data-poll-id');
                fetch('/blocks/credenciales/ajax_status.php?cert_id=' + certId)
                    .then(response => response.json())
                    .then(data => {
                        if (data.status === 'claimed') {
                            // Automatically close QR Modal if open
                            if (typeof window.jQuery !== 'undefined') {
                                jQuery('#qrModal' + certId).modal('hide');
                                // Ensure modal backdrop is forcefully removed in case of race condition
                                setTimeout(() => { jQuery('.modal-backdrop').remove(); jQuery('body').removeClass('modal-open'); }, 350);
                            }

                            // Hide Pending Actions & Badge
                            el.style.opacity = '0';
                            const pendingBadge = document.querySelector('.badge-pending-' + certId);
                            if(pendingBadge) pendingBadge.style.opacity = '0';
                            
                            setTimeout(() => {
                                el.style.display = 'none';
                                if(pendingBadge) pendingBadge.style.display = 'none';
                                
                                // Show Claimed Info
                                const claimedActions = document.querySelector('.claimed-actions-' + certId);
                                const claimedBadge = document.querySelector('.badge-claimed-' + certId);
                                const dateClaimed = document.querySelector('.date-claimed-' + certId);
                                const timeText = document.querySelector('.time-text-' + certId);
                                
                                if (timeText && data.exact_claimed_time) {
                                    timeText.textContent = data.exact_claimed_time;
                                }

                                if (claimedActions) {
                                    claimedActions.style.display = 'block';
                                    setTimeout(() => claimedActions.style.opacity = '1', 50);
                                }
                                if (claimedBadge) {
                                    claimedBadge.style.display = 'inline-flex';
                                    setTimeout(() => claimedBadge.style.opacity = '1', 50);
                                }
                                if (dateClaimed) {
                                    dateClaimed.style.display = 'block';
                                    setTimeout(() => dateClaimed.style.opacity = '1', 50);
                                }
                            }, 300); // Wait for fade out
                        }
                    })
                    .catch(err => console.error('Poller error:', err));
            });
        }, 3000);
    });

    // Función pura JS para renderización Vector-to-Raster del Diploma
    function downloadDiplomaAsImage(certId) {
        if (typeof html2canvas === 'undefined') {
            alert('Cargando motor de renderizado gráfico, por favor intenta en un segundo...');
            return;
        }
        
        const certElement = document.querySelector('#certModal' + certId + ' .md3-certificate-illustration');
        const btn = document.querySelector('#downloadBtn' + certId);
        
        if (!certElement || !btn) return;
        
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin mr-2"></i> Procesando vectores...';
        btn.disabled = true;

        html2canvas(certElement, {
            scale: 3, // Calidad de imprenta (Hi-Res)
            useCORS: true,
            backgroundColor: null,
            logging: false
        }).then(canvas => {
            const link = document.createElement('a');
            link.download = 'Diploma_Universitario_' + certId + '.png';
            link.href = canvas.toDataURL('image/png');
            link.click();
            
            btn.innerHTML = '<i class="fa fa-check mr-2"></i> Descargado Exitosamente';
            btn.classList.replace('md3-btn-secondary', 'md3-btn-primary');
            setTimeout(() => {
                btn.innerHTML = originalHtml;
                btn.classList.replace('md3-btn-primary', 'md3-btn-secondary');
                btn.disabled = false;
            }, 3000);
        }).catch(err => {
            console.error('Render Engine Error:', err);
            btn.innerHTML = '<i class="fa fa-exclamation-triangle mr-2"></i> Error al generar';
            setTimeout(() => { btn.innerHTML = originalHtml; btn.disabled = false; }, 3000);
        });
    }
</script>
<!-- CDN para motor de renderizado Canvas -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
{{/has_certificates}}
